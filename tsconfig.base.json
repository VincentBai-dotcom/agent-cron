{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@agent-cron/adapters-github": ["packages/adapters-github/src/index.ts"],
      "@agent-cron/adapters-xiaohongshu": ["packages/adapters-xiaohongshu/src/index.ts"],
      "@agent-cron/db": ["packages/db/src/index.ts"],
      "@agent-cron/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@agent-cron/shared": ["packages/shared/src/index.ts"],
      "@agent-cron/task-registry": ["packages/task-registry/src/index.ts"]
    },
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  }
}
